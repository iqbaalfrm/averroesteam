APP_ENV=development
SECRET_KEY=ganti-dengan-secret-kuat
JWT_SECRET_KEY=ganti-dengan-jwt-secret-kuat
MONGODB_URI=mongodb://localhost:27017
DB_NAME=averroes_db
UPLOAD_FOLDER=uploads
NISHAB_DUMMY=85000000
JWT_ACCESS_TOKEN_EXPIRES=86400
MAX_CONTENT_LENGTH=10485760
USE_PROXY_FIX=true
PREFERRED_URL_SCHEME=https
GOOGLE_OAUTH_CLIENT_IDS=
SUPABASE_AUTH_ENABLED=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_AUTO_SYNC_USERS=true
LEGACY_JWT_ENABLED=true
AUTH_TRANSITION_ALLOW_LEGACY=true
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_CLIENT_ID=
POSTGRES_URL=
SUPABASE_DB_URL=
SUPABASE_MIGRATION_CREATE_AUTH_USERS=false

# Seed dev only
ADMIN_EMAIL=admin@averroes.local
ADMIN_PASSWORD=admin123

# Crypto news scraping
NEWS_SCRAPER_ENABLED=true
NEWS_SCRAPER_INTERVAL_SECONDS=21600
NEWS_SCRAPER_LIMIT=20
NEWS_SCRAPER_RUN_ON_STARTUP=true
NEWS_SCRAPER_FEEDS=https://news.google.com/rss/search?q=crypto&hl=id&gl=ID&ceid=ID:id
