APP_ENV=development
SECRET_KEY=ganti-dengan-secret-kuat
JWT_SECRET_KEY=ganti-dengan-jwt-secret-kuat
MONGODB_URI=mongodb://localhost:27017
DB_NAME=averroes_db
UPLOAD_FOLDER=uploads
NISHAB_DUMMY=85000000
JWT_ACCESS_TOKEN_EXPIRES=86400
MAX_CONTENT_LENGTH=10485760
USE_PROXY_FIX=true
PREFERRED_URL_SCHEME=https

# Seed dev only
ADMIN_EMAIL=admin@averroes.local
ADMIN_PASSWORD=admin123

# Crypto news scraping
NEWS_SCRAPER_ENABLED=true
NEWS_SCRAPER_INTERVAL_SECONDS=21600
NEWS_SCRAPER_LIMIT=20
NEWS_SCRAPER_RUN_ON_STARTUP=true
NEWS_SCRAPER_FEEDS=https://cryptowave.co.id/
